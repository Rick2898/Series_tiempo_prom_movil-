    "# Últimos 2 valores reales (mayo y junio 2019)\n",
    "last_two = ocupados[-window:].values.tolist()\n",
    "\n",
    "for i in range(6):\n",
    "    # Pronóstico = promedio de los últimos 2 valores (reales o pronosticados)\n",
