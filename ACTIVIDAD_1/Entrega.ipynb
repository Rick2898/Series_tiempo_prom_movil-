    "# Gráfica comparativa entre datos reales y pronóstico\n",
    "plt.figure(figsize=(12,6))\n",
    "plt.plot(train_oc['2018-01':], label='Histórico (Train)')\n",
    "plt.plot(test_oc, label='Real (Test)', marker='o')\n",
    "plt.plot(forecast_series, label='Pronóstico MA(2)', marker='x', linestyle='--')\n",
    "plt.title('Pronóstico de Ocupados - Promedio Móvil Orden 2')\n",
    "plt.legend()\n",
    "plt.grid()\n",
    "plt.show()"
   ]
